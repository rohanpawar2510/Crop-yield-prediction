# Environment variables for add_humidity_to_csv.py
#
# Copy this file to .env in the same directory and fill in your API key:
#
#   cp .env.example .env
#
# The .env file is loaded automatically when the script runs
# (requires: pip install python-dotenv)

# OpenWeather API key (free tier is sufficient — https://openweathermap.org/api)
# Leave blank to run in estimation mode (no API calls)
OPENWEATHER_API_KEY=your_openweather_api_key_here
